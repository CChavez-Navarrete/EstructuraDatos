  <property name="styleSheet">
   <string notr="true">/* ====== MAIN WINDOW ====== */
QMainWindow {
    background-color: #f5f7fa;
}

/* ====== MENUBAR ====== */
QMenuBar {
    background-color: #2c3e50;
    color: white;
    border: none;
    padding: 4px;
    font-size: 10pt;
    font-weight: bold;
}

QMenuBar::item {
    background: transparent;
    padding: 8px 15px;
    margin: 2px;
    border-radius: 4px;
}

QMenuBar::item:selected {
    background-color: #34495e;
}

QMenuBar::item:pressed {
    background-color: #1abc9c;
}

/* ====== MENUS DESPLEGABLES ====== */
QMenu {
    background-color: white;
    border: 1px solid #dcdfe3;
    padding: 5px;
}

QMenu::item {
    padding: 8px 30px 8px 25px;
    color: #2c3e50;
    border-radius: 3px;
}

QMenu::item:selected {
    background-color: #3498db;
    color: white;
}

QMenu::separator {
    height: 1px;
    background: #dcdfe3;
    margin: 5px 10px;
}

/* ====== STATUS BAR ====== */
QStatusBar {
    background-color: #ecf0f1;
    color: #34495e;
    border-top: 1px solid #dcdfe3;
    padding-left: 8px;
}

/* ====== BOTONES ====== */
QPushButton {
    background-color: #3498db;
    color: white;
    border: none;
    border-radius: 5px;
    padding: 8px 15px;
    font-weight: bold;
}

QPushButton:hover {
    background-color: #2980b9;
}

QPushButton:pressed {
    background-color: #21618c;
}

QPushButton:disabled {
    background-color: #bdc3c7;
    color: #7f8c8d;
}

/* ====== CAMPOS DE TEXTO ====== */
QLineEdit,
QTextEdit,
QPlainTextEdit {
    background-color: white;
    border: 1px solid #bdc3c7;
    border-radius: 5px;
    padding: 5px;
    color: #2c3e50;
}

QLineEdit:focus,
QTextEdit:focus,
QPlainTextEdit:focus {
    border: 2px solid #3498db;
}

/* ====== TABLAS ====== */
QTableWidget,
QTableView {
    background-color: white;
    alternate-background-color: #f8f9fa;
    border: 1px solid #dcdfe3;
    gridline-color: #dcdfe3;
    selection-background-color: #3498db;
    selection-color: white;
}

QHeaderView::section {
    background-color: #34495e;
    color: white;
    padding: 6px;
    border: none;
    font-weight: bold;
}

/* ====== COMBOBOX ====== */
QComboBox {
    background-color: white;
    border: 1px solid #bdc3c7;
    border-radius: 5px;
    padding: 5px;
}

QComboBox:hover {
    border: 1px solid #3498db;
}

/* ====== GROUPBOX ====== */
QGroupBox {
    border: 1px solid #dcdfe3;
    border-radius: 6px;
    margin-top: 10px;
    font-weight: bold;
    color: #2c3e50;
}

QGroupBox::title {
    subcontrol-origin: margin;
    left: 10px;
    padding: 0 5px;
}

/* ====== SCROLLBAR ====== */
QScrollBar:vertical {
    background: #ecf0f1;
    width: 12px;
    border-radius: 5px;
}

QScrollBar::handle:vertical {
    background: #95a5a6;
    border-radius: 5px;
}

QScrollBar::handle:vertical:hover {
    background: #7f8c8d;
}
</string>
  </property>
