  <property name="styleSheet">
   <string notr="true">/* Estilo para la ventana de diálogo principal */
QDialog {
    background-color: #1e1e24;
    font-family: &quot;Segoe UI&quot;, sans-serif;
}

/* Estilo general para todos los botones (QPushButton) */
QPushButton {
    background-color: #2b2b36;
    color: #ffffff;
    border: 1px solid #3a3a45;
    border-radius: 5px;
    padding: 6px 14px;
    font-size: 13px;
    font-weight: bold;
}

/* Efecto cuando pasas el mouse sobre cualquier botón */
QPushButton:hover {
    background-color: #333344;
    border: 1px solid #29b6f6; /* Borde azul brillante */
}

/* Efecto cuando le das clic a un botón */
QPushButton:pressed {
    background-color: #29b6f6;
    color: #101014;
}

/* --- ESTILOS ESPECÍFICOS PARA CIERTOS BOTONES --- */

/* Botones de acción principal (agregarF y agregarl) */
QPushButton#agregarF, QPushButton#agregarl {
    border: 1px solid #29b6f6;
    color: #29b6f6;
}
QPushButton#agregarF:hover, QPushButton#agregarl:hover {
    background-color: #29b6f6;
    color: #101014;
}

/* Botones de peligro/borrado (deleteFiNAL y deleteINICIO) */
QPushButton#deleteFiNAL, QPushButton#deleteINICIO {
    color: #ff5252; /* Texto rojo */
    border: 1px solid #5c2626;
}
QPushButton#deleteFiNAL:hover, QPushButton#deleteINICIO:hover {
    background-color: #ff5252;
    color: #101014; /* Texto oscuro al activarse */
    border: 1px solid #ff5252;
}

/* Estilo general para los textos/etiquetas (QLabel) */
QLabel {
    color: #e0e0e0;
    font-size: 13px;
}

/* Estilo específico para la etiqueta donde muestras la lista o respuesta (resultado) */
QLabel#resultado {
    background-color: #141419;
    color: #29b6f6; /* Texto azul para resaltar los datos */
    border: 1px solid #2d2d34;
    border-radius: 4px;
    padding: 8px;
    font-family: &quot;Consolas&quot;, &quot;Courier New&quot;, monospace; /* Fuente monoespaciada ideal para ver la estructura */
    font-size: 14px;
}

/* Estilo para los títulos o textos fijos (ingresarDato, label) */
QLabel#ingresarDato, QLabel#label {
    font-weight: bold;
    color: #ffffff;
}</string>
